    .equalizer {
      position: absolute;
      right: 7%;
      bottom: 28%;
      z-index: 9;
      display: flex;
      align-items: end;
      gap: 5px;
      height: 54px;
      pointer-events: none;
      opacity: .35;
      transition: opacity .35s ease, filter .35s ease;
    }

    .vinyl-scene.music-on .equalizer {
      opacity: 1;
      filter: drop-shadow(0 0 12px rgba(255,211,106,.32));
    }

    .eq-bar {
      width: 6px;
      height: 16px;
      border-radius: 999px;
      background: linear-gradient(180deg, #fff6ce, #ffd36a 52%, #ff7aa9);
      transform-origin: bottom;
      animation: eqIdle 2.2s ease-in-out infinite alternate;
      animation-play-state: paused;
    }

    .eq-bar:nth-child(2) { height: 28px; animation-delay: -.3s; }
    .eq-bar:nth-child(3) { height: 20px; animation-delay: -.55s; }
    .eq-bar:nth-child(4) { height: 36px; animation-delay: -.1s; }
    .eq-bar:nth-child(5) { height: 24px; animation-delay: -.45s; }
    .eq-bar:nth-child(6) { height: 42px; animation-delay: -.7s; }

    .vinyl-scene.music-on .eq-bar {
      animation-name: eqDance;
      animation-duration: .78s;
      animation-play-state: running;
    }

    @keyframes eqDance {
      0% { transform: scaleY(.38); opacity: .76; }
      35% { transform: scaleY(1.18); opacity: 1; }
      70% { transform: scaleY(.65); opacity: .88; }
      100% { transform: scaleY(1); opacity: 1; }
    }

    @keyframes eqIdle {
      to { transform: scaleY(.56); }
    }

    .sound-waves {
      position: absolute;
      left: 5.2%;
      top: 50%;
      z-index: 3;
      width: min(500px, 58vw);
      aspect-ratio: 1 / 1;
      transform: translateY(-50%);
      pointer-events: none;
      opacity: 0;
      transition: opacity .55s ease;
    }

    .vinyl-scene.music-on .sound-waves {
      opacity: 1;
    }

    .wave {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(255,211,106,.2);
      animation: wave 2.6s ease-out infinite;
    }

    .wave:nth-child(2) { animation-delay: .75s; border-color: rgba(255, 95, 159, .18); }
    .wave:nth-child(3) { animation-delay: 1.5s; border-color: rgba(124, 60, 255, .18); }

    @keyframes wave {
      from { transform: scale(.76); opacity: .72; }
      to { transform: scale(1.28); opacity: 0; }
    }

    .music-notes {
      position: absolute;
      inset: 0;
      z-index: 4;
      pointer-events: none;
      opacity: 0;
      transition: opacity .45s ease;
    }

    .vinyl-scene.music-on .music-notes {
      opacity: 1;
    }

    .music-note {
      position: absolute;
      left: var(--x);
      bottom: var(--y);
      color: rgba(255, 240, 186, .86);
      font-size: clamp(16px, 2.2vw, 28px);
      text-shadow: 0 0 16px rgba(255,211,106,.52);
      animation: noteFloat var(--d) ease-in-out infinite;
      animation-delay: var(--delay);
    }

    @keyframes noteFloat {
      0% { transform: translate3d(0, 18px, 0) rotate(-8deg); opacity: 0; }
      18% { opacity: .9; }
      100% { transform: translate3d(var(--dx), -150px, 0) rotate(18deg); opacity: 0; }
    }

    .vinyl-copy {
      position: absolute;
      left: 50%;
      bottom: clamp(24px, 5vw, 42px);
      width: min(92vw, 760px);
      transform: translateX(-50%);
