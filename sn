<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Happy Birthday Nguyễn Văn Kiên</title>

  <!-- External animation libraries via CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/howler/2.2.4/howler.min.js"></script>

  <style>

    /* =========================
       Base / Theme
    ========================== */
    :root {
      --black: #050307;
      --wine: #6f0f22;
      --wine-dark: #31040f;
      --gold: #ffd36a;
      --gold-soft: #fff0ba;
      --cream: #fff6dc;
      --purple: #7c3cff;
      --pink: #ff5f9f;
      --blue: #66d9ff;
      --glass: rgba(255,255,255,0.09);
      --glass-strong: rgba(255,255,255,0.16);
      --shadow: 0 24px 80px rgba(0,0,0,0.55);
      --ease: cubic-bezier(.2,.9,.2,1);
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      overflow: hidden;
      background: var(--black);
      color: var(--cream);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      width: 100vw;
      height: 100vh;
      background:
        radial-gradient(circle at 50% 30%, rgba(125, 60, 255, 0.18), transparent 34%),
        radial-gradient(circle at 16% 15%, rgba(255, 211, 106, 0.16), transparent 28%),
        linear-gradient(180deg, #09050d 0%, #030204 100%);
    }

    button {
      font: inherit;
      border: 0;
      cursor: pointer;
      color: inherit;
    }

    .app {
      position: relative;
      width: 100vw;
      height: 100vh;
      isolation: isolate;
      overflow: hidden;
    }

    .scene {
      position: absolute;
      inset: 0;
      z-index: 2;
      width: 100%;
      height: 100%;
      display: grid;
      place-items: center;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: scale(1.02);
      filter: blur(8px);
      transition: opacity .8s var(--ease), transform 1s var(--ease), filter 1s var(--ease), visibility 0s linear .8s;
    }

    .scene.active {
      z-index: 20;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: scale(1);
      filter: blur(0);
      transition-delay: 0s;
    }

    .scene:not(.active),
    .scene:not(.active) * {
      pointer-events: none !important;
    }

    #particles,
    #vinylParticles {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
    }

    .aurora {
      position: absolute;
      inset: -24%;
      z-index: 0;
      opacity: .5;
      pointer-events: none;
      background:
        radial-gradient(circle at 18% 20%, rgba(255, 211, 106, .2), transparent 18%),
        radial-gradient(circle at 78% 22%, rgba(124, 60, 255, .24), transparent 22%),
        radial-gradient(circle at 50% 80%, rgba(255, 95, 159, .12), transparent 28%);
      filter: blur(34px);
      animation: auroraMove 15s linear infinite alternate;
    }

    @keyframes auroraMove {
      from { transform: translate3d(-2%, -1%, 0) rotate(0deg) scale(1); }
      to { transform: translate3d(2%, 2%, 0) rotate(5deg) scale(1.06); }
    }

    .light-sweep {
      position: absolute;
      top: -12%;
      left: -25%;
      width: 48%;
      height: 140%;
      z-index: 3;
      opacity: .38;
      background: linear-gradient(100deg, transparent 0%, rgba(255,255,255,.06) 40%, rgba(255, 231, 156, .18) 50%, transparent 64%);
      transform: skewX(-15deg);
      pointer-events: none;
      animation: sweep 7s ease-in-out infinite;
      mix-blend-mode: screen;
    }

    @keyframes sweep {
      0%, 18% { transform: translateX(0) skewX(-15deg); opacity: 0; }
      36% { opacity: .42; }
      58%, 100% { transform: translateX(310%) skewX(-15deg); opacity: 0; }
    }

    .btn {
      position: relative;
      padding: 16px 30px;
      border-radius: 999px;
      background:
        linear-gradient(135deg, rgba(255,211,106,.98), rgba(255, 140, 87, .94)),
        linear-gradient(180deg, rgba(255,255,255,.2), transparent);
      color: #1b0b0e;
      font-weight: 900;
      letter-spacing: .02em;
      box-shadow:
        0 0 28px rgba(255, 211, 106, .36),
        0 16px 34px rgba(0,0,0,.48),
        inset 0 1px 0 rgba(255,255,255,.75);
      transform: translateZ(0);
      transition: transform .28s var(--ease), filter .28s var(--ease), box-shadow .28s var(--ease);
      overflow: hidden;
    }

    .btn::before {
      content: "";
      position: absolute;
      inset: -30% -55%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.55), transparent);
      transform: translateX(-80%) rotate(14deg);
      transition: transform .7s ease;
    }

    .btn:hover,
    .btn:focus-visible {
      transform: translateY(-3px) scale(1.025);
      filter: brightness(1.08);
      box-shadow:
        0 0 38px rgba(255, 211, 106, .48),
        0 20px 44px rgba(0,0,0,.52),
        inset 0 1px 0 rgba(255,255,255,.78);
    }

    .btn:hover::before,
    .btn:focus-visible::before {
      transform: translateX(105%) rotate(14deg);
    }

    .btn.secondary {
      background: linear-gradient(135deg, rgba(255,255,255,.15), rgba(255,255,255,.06));
      color: var(--cream);
      border: 1px solid rgba(255,255,255,.18);
      backdrop-filter: blur(14px);
      box-shadow: 0 14px 36px rgba(0,0,0,.42), inset 0 1px 0 rgba(255,255,255,.16);
    }

    .music-toggle {
      position: fixed;
      top: clamp(14px, 3vw, 26px);
      right: clamp(14px, 3vw, 26px);
      z-index: 60;
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.18);
      backdrop-filter: blur(18px);
      color: var(--gold-soft);
      box-shadow: 0 14px 38px rgba(0,0,0,.38), 0 0 28px rgba(255,211,106,.12);
      opacity: 0;
      transform: translateY(-8px) scale(.9);
      pointer-events: none;
      transition: opacity .45s ease, transform .45s ease, background .3s ease;
    }

    .music-toggle.visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .music-toggle:hover {
      background: rgba(255,255,255,.16);
      transform: translateY(-2px) scale(1.05);
    }

    .music-toggle .icon {
      font-size: 21px;
      line-height: 1;
    }

    .glass-card {
      position: relative;
      z-index: 4;
      padding: clamp(24px, 5vw, 48px);
      border-radius: 32px;
      background: linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.05));
      border: 1px solid rgba(255,255,255,.16);
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,.18);
      backdrop-filter: blur(18px);
    }

    .screen-shake {
      animation: shake .58s cubic-bezier(.36,.07,.19,.97) both;
    }

    @keyframes shake {
      10%, 90% { transform: translate3d(-1px, 0, 0); }
      20%, 80% { transform: translate3d(2px, 0, 0); }
      30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
      40%, 60% { transform: translate3d(4px, 0, 0); }
    }

    /* =========================
       Loading Scene
    ========================== */
    .loading-scene {
      background:
        radial-gradient(circle at 50% 42%, rgba(255, 211, 106, .16), transparent 30%),
        radial-gradient(circle at 50% 50%, #140813 0%, #050307 62%, #010102 100%);
    }

    .loader-card {
      width: min(88vw, 520px);
      text-align: center;
    }

    .loading-ring {
      width: 118px;
      height: 118px;
      margin: 0 auto 26px;
      border-radius: 50%;
      position: relative;
      display: grid;
      place-items: center;
      background:
        conic-gradient(from 0deg, rgba(255,211,106,0), rgba(255,211,106,1), rgba(124,60,255,.85), rgba(255,95,159,.85), rgba(255,211,106,0));
      box-shadow: 0 0 46px rgba(255,211,106,.28);
      animation: spin 1.35s linear infinite;
    }

    .loading-ring::before {
      content: "";
      position: absolute;
      inset: 9px;
      border-radius: inherit;
      background: rgba(8,4,9,.96);
      box-shadow: inset 0 0 34px rgba(255,211,106,.1);
    }

    .loading-ring::after {
      content: "✦";
      z-index: 1;
      color: var(--gold);
      font-size: 30px;
      text-shadow: 0 0 18px rgba(255,211,106,.95);
      animation: pulseStar 1.2s ease-in-out infinite alternate;
    }

    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes pulseStar { to { transform: scale(1.24); filter: brightness(1.3); } }

    .loading-title {
      margin: 0 0 22px;
      font-size: clamp(1.25rem, 3vw, 2.15rem);
      font-weight: 800;
      letter-spacing: -.02em;
      color: var(--cream);
      text-shadow: 0 0 22px rgba(255,211,106,.22);
    }

    .loading-bar {
      position: relative;
      height: 12px;
      width: 100%;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      box-shadow: inset 0 0 18px rgba(0,0,0,.5);
    }

    .loading-progress {
      width: 0%;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--gold), #fff2bd, var(--pink), var(--purple));
      box-shadow: 0 0 24px rgba(255,211,106,.55);
    }

    /* =========================
       Start Scene
    ========================== */
    .start-scene {
      background:
        linear-gradient(180deg, rgba(3,2,4,.35), rgba(0,0,0,.9)),
        radial-gradient(circle at 50% 12%, rgba(255,211,106,.14), transparent 32%),
        radial-gradient(circle at 50% 55%, rgba(88, 12, 36, .35), transparent 42%),
        #050307;
    }

    .start-content {
      position: relative;
      width: min(92vw, 900px);
      text-align: center;
      z-index: 25;
      padding-inline: 18px;
      pointer-events: auto;
    }

    #startBtn,
    #restartBtn,
    #closeLetterBtn,
    #musicToggle {
      position: relative;
      z-index: 80;
      pointer-events: auto;
      touch-action: manipulation;
    }

    .eyebrow {
      margin-bottom: 18px;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: .28em;
      font-size: .78rem;
      font-weight: 800;
      opacity: .86;
    }

    .start-title {
      min-height: 2.4em;
      margin: 0 auto 28px;
      max-width: 840px;
      font-size: clamp(2.05rem, 6.3vw, 5.6rem);
      line-height: .98;
      font-weight: 950;
      letter-spacing: -.065em;
      background: linear-gradient(115deg, #fff7d7 0%, #ffd36a 35%, #ff91bc 68%, #d7c4ff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 20px 80px rgba(255,211,106,.12);
    }

    .type-caret {
      display: inline-block;
      width: .055em;
      min-width: 2px;
      height: .86em;
      margin-left: .08em;
      vertical-align: -.08em;
      background: var(--gold);
      box-shadow: 0 0 14px var(--gold);
      animation: caret .78s steps(1) infinite;
    }

    @keyframes caret { 50% { opacity: 0; } }

    .start-subtitle {
      margin: 0 auto 34px;
      max-width: 650px;
      font-size: clamp(.98rem, 2.2vw, 1.18rem);
      line-height: 1.7;
      color: rgba(255,246,220,.78);
    }

    .stage-preview {
      position: absolute;
      inset: auto 0 0;
      height: 36vh;
      z-index: 2;
      opacity: .55;
      background:
        linear-gradient(90deg, rgba(80, 4, 20, .72), transparent 18%, transparent 82%, rgba(80,4,20,.72)),
        linear-gradient(180deg, transparent, rgba(0,0,0,.8));
      pointer-events: none;
    }

    .start-spotlight {
      position: absolute;
      top: -20%;
      left: 50%;
      z-index: 1;
      width: 34vw;
      min-width: 280px;
      height: 90vh;
      transform: translateX(-50%);
      clip-path: polygon(42% 0, 58% 0, 100% 100%, 0 100%);
      background: linear-gradient(180deg, rgba(255,230,162,.2), rgba(255,211,106,.04) 60%, transparent);
      filter: blur(6px);
      animation: spotlightBreathe 5.2s ease-in-out infinite alternate;
      mix-blend-mode: screen;
    }

    @keyframes spotlightBreathe {
      to { opacity: .65; transform: translateX(-50%) scaleX(1.14); }
    }

    /* =========================
       Stage Scene
    ========================== */
    .stage-scene {
      perspective: 1100px;
      background:
        radial-gradient(circle at 50% 25%, rgba(255,211,106,.12), transparent 22%),
        linear-gradient(180deg, #0c0610 0%, #070407 48%, #030203 100%);
    }

    .theater {
      position: absolute;
      inset: 0;
      z-index: 3;
      transform-style: preserve-3d;
      overflow: hidden;
    }

    .stage-backdrop {
      position: absolute;
      left: 50%;
      top: 11%;
      width: min(1080px, 92vw);
      height: min(520px, 56vh);
      transform: translateX(-50%) translateZ(-80px);
      border-radius: 32px 32px 12px 12px;
      background:
        radial-gradient(circle at 50% 40%, rgba(255, 211, 106, .13), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.015)),
        #0a0610;
      border: 1px solid rgba(255,255,255,.1);
      box-shadow: inset 0 0 90px rgba(0,0,0,.78), 0 0 80px rgba(124,60,255,.12);
      overflow: hidden;
    }

    .shadow-play {
      position: absolute;
      inset: 0;
      opacity: .55;
      overflow: hidden;
    }

    .silhouette {
      position: absolute;
      bottom: 12%;
      width: 54px;
      height: 90px;
      border-radius: 50% 50% 35% 35%;
      background: rgba(0,0,0,.72);
      filter: blur(.2px);
      animation: silhouetteMove 9s ease-in-out infinite alternate;
    }

    .silhouette::before {
      content: "";
      position: absolute;
      top: -26px;
      left: 12px;
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: rgba(0,0,0,.72);
    }

    .silhouette.one { left: 18%; animation-delay: -.8s; transform: scale(.9); }
    .silhouette.two { right: 20%; animation-delay: -2.5s; transform: scale(.74); }

    .balloon-shadow {
      position: absolute;
      width: 36px;
      height: 46px;
      border-radius: 50% 50% 45% 45%;
      background: rgba(0,0,0,.54);
      bottom: 48%;
      animation: floatShadow 6s ease-in-out infinite alternate;
    }

    .balloon-shadow::after {
      content: "";
      position: absolute;
      top: 45px;
      left: 50%;
      width: 1px;
      height: 60px;
      background: rgba(0,0,0,.45);
    }

    .balloon-shadow.b1 { left: 31%; animation-delay: -1s; }
    .balloon-shadow.b2 { right: 32%; transform: scale(.82); animation-delay: -3s; }

    @keyframes silhouetteMove {
      from { translate: -8px 0; }
      to { translate: 8px -4px; }
    }

    @keyframes floatShadow {
      from { translate: 0 8px; }
      to { translate: 0 -16px; }
    }

    .curtain {
      position: absolute;
      top: 0;
      width: 52%;
      height: 100%;
      z-index: 16;
      background:
        repeating-linear-gradient(90deg, rgba(255,255,255,.07) 0 3px, transparent 3px 22px),
        radial-gradient(circle at 30% 18%, rgba(255,255,255,.13), transparent 24%),
        linear-gradient(90deg, #3f0613, #9d1730 45%, #4d0717 100%);
      box-shadow: inset 0 0 55px rgba(0,0,0,.55), 0 0 34px rgba(0,0,0,.65);
      transform-origin: top center;
    }

    .curtain.left {
      left: 0;
      border-right: 3px solid rgba(255,211,106,.32);
    }

    .curtain.right {
      right: 0;
      border-left: 3px solid rgba(255,211,106,.32);
      transform: scaleX(-1);
    }

    .curtain-top {
      position: absolute;
      left: 0;
      top: 0;
      z-index: 17;
      width: 100%;
      height: clamp(70px, 12vh, 120px);
      background:
        repeating-linear-gradient(90deg, transparent 0 24px, rgba(0,0,0,.18) 24px 42px),
        linear-gradient(180deg, #a21732, #5c0718);
      box-shadow: inset 0 -18px 32px rgba(0,0,0,.45), 0 18px 38px rgba(0,0,0,.34);
      border-bottom: 2px solid rgba(255,211,106,.25);
    }

    .spotlight {
      position: absolute;
      top: -10%;
      left: 50%;
      width: min(560px, 70vw);
      height: 86vh;
      z-index: 5;
      transform: translateX(-50%);
      clip-path: polygon(45% 0, 55% 0, 100% 100%, 0 100%);
      background: linear-gradient(180deg, rgba(255, 229, 156, .26), rgba(255,211,106,.08) 58%, transparent);
      filter: blur(8px);
      mix-blend-mode: screen;
      opacity: .75;
      pointer-events: none;
    }

    .side-light {
      position: absolute;
      top: 4%;
      width: 24vw;
      min-width: 220px;
      height: 70vh;
      z-index: 4;
      background: linear-gradient(180deg, rgba(124,60,255,.2), transparent);
      filter: blur(10px);
      clip-path: polygon(0 0, 18% 0, 100% 100%, 0 100%);
      opacity: .48;
      pointer-events: none;
    }

    .side-light.left { left: -4%; transform: rotate(-10deg); }
    .side-light.right { right: -4%; transform: scaleX(-1) rotate(-10deg); }

    .stage-floor {
      position: absolute;
      left: 50%;
      bottom: -6%;
      width: min(1220px, 112vw);
      height: 35vh;
      z-index: 6;
      transform: translateX(-50%) rotateX(58deg);
      transform-origin: bottom center;
      border-radius: 50% 50% 0 0 / 20% 20% 0 0;
      background:
        repeating-linear-gradient(90deg, rgba(255,255,255,.04) 0 2px, transparent 2px 82px),
        linear-gradient(90deg, rgba(80, 36, 15, .9), rgba(126, 63, 23, .94), rgba(70, 27, 13, .9));
      box-shadow: inset 0 30px 70px rgba(255,211,106,.08), 0 -20px 55px rgba(0,0,0,.5);
    }

    .floor-glow {
      position: absolute;
      left: 50%;
      bottom: 14%;
      z-index: 7;
      width: min(680px, 86vw);
      height: 90px;
      transform: translateX(-50%);
      background: radial-gradient(ellipse, rgba(255,211,106,.24), transparent 70%);
      filter: blur(10px);
      opacity: .7;
      pointer-events: none;
    }

    .smoke {
      position: absolute;
      left: -10%;
      right: -10%;
      bottom: 7%;
      height: 26vh;
      z-index: 11;
      pointer-events: none;
      background:
        radial-gradient(ellipse at 18% 64%, rgba(255,255,255,.14), transparent 35%),
        radial-gradient(ellipse at 52% 80%, rgba(255,255,255,.1), transparent 40%),
        radial-gradient(ellipse at 82% 70%, rgba(255,255,255,.12), transparent 35%);
      filter: blur(22px);
      opacity: .48;
      animation: smokeMove 10s ease-in-out infinite alternate;
    }

    @keyframes smokeMove {
      from { transform: translateX(-2%) scale(1); }
      to { transform: translateX(2%) scale(1.05); }
    }

    /* =========================
       Cart + Mystery Cloth
    ========================== */
    .cart-wrap {
      position: absolute;
      left: -420px;
      bottom: 20%;
      z-index: 21;
      width: 360px;
      height: 220px;
      filter: drop-shadow(0 26px 30px rgba(0,0,0,.46));
      transform-origin: center bottom;
    }

    .cart-trail {
      position: absolute;
      left: -160px;
      top: 122px;
      width: 180px;
      height: 32px;
      background: linear-gradient(90deg, transparent, rgba(255,211,106,.22), transparent);
      filter: blur(10px);
      opacity: .7;
    }

    .mystery-cloth {
      position: absolute;
      left: 86px;
      bottom: 58px;
      width: 210px;
      height: 154px;
      border-radius: 42% 42% 16% 16% / 32% 32% 18% 18%;
      background:
        radial-gradient(circle at 38% 18%, rgba(255,255,255,.25), transparent 20%),
        repeating-linear-gradient(90deg, rgba(255,255,255,.1) 0 4px, transparent 4px 26px),
        linear-gradient(135deg, #fff2ca, #dca545 42%, #7b3016 100%);
      box-shadow: inset 0 -26px 36px rgba(66, 16, 4, .42), 0 16px 34px rgba(0,0,0,.36);
      transform-origin: 50% 8%;
    }

    .mystery-cloth::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -18px;
      height: 34px;
      border-radius: 0 0 40px 40px;
      background: repeating-linear-gradient(90deg, #c78327 0 18px, #f7d77d 18px 35px);
      box-shadow: 0 10px 18px rgba(0,0,0,.22);
    }

    .cart-rope {
      position: absolute;
      left: 22px;
      top: 112px;
      width: 96px;
      height: 4px;
      background: linear-gradient(90deg, #9a6d34, #ffd36a);
      transform: rotate(-5deg);
      transform-origin: right center;
      box-shadow: 0 0 10px rgba(255,211,106,.28);
    }

    .cart-body {
      position: absolute;
      left: 22px;
      bottom: 32px;
      width: 284px;
      height: 70px;
      border-radius: 30px 30px 24px 24px;
      background: linear-gradient(135deg, #74172b, #b6203d 48%, #5a0719);
      border: 1px solid rgba(255,211,106,.45);
      box-shadow: inset 0 12px 20px rgba(255,255,255,.08), 0 12px 28px rgba(0,0,0,.36);
    }

    .cart-body::before {
      content: "";
      position: absolute;
      inset: 12px 25px auto;
      height: 12px;
      border-radius: 999px;
      background: linear-gradient(90deg, transparent, rgba(255,211,106,.55), transparent);
    }

    .wheel {
      position: absolute;
      bottom: 0;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background:
        radial-gradient(circle, #1b0b0f 0 16%, #f5c85f 17% 25%, #271015 26% 52%, #ffd36a 53% 61%, #13070a 62% 100%);
      box-shadow: 0 7px 16px rgba(0,0,0,.5);
    }

    .wheel.left { left: 62px; }
    .wheel.right { right: 54px; }

    .cart-star {
      position: absolute;
      right: 28px;
      top: 8px;
      color: var(--gold);
      text-shadow: 0 0 16px var(--gold);
      font-size: 22px;
      animation: sparklePulse 1.6s ease-in-out infinite alternate;
    }

    @keyframes sparklePulse {
      to { transform: scale(1.25) rotate(12deg); filter: brightness(1.4); }
    }

    /* =========================
       Cake / Letter / Knife
    ========================== */
    .cake-area {
      position: absolute;
      left: 50%;
      bottom: 20%;
      z-index: 20;
      width: min(760px, 94vw);
      height: min(430px, 55vh);
      transform: translateX(-50%);
      pointer-events: none;
    }

    .cake-wrapper {
      position: absolute;
      left: 50%;
      bottom: 0;
      width: clamp(250px, 44vw, 420px);
      height: clamp(250px, 42vw, 390px);
      transform: translateX(-50%) translateY(140px) scale(.8);
      opacity: 0;
      pointer-events: none;
      cursor: default;
      transform-style: preserve-3d;
      filter: drop-shadow(0 30px 38px rgba(0,0,0,.56));
    }

    .cake-wrapper.cut-ready {
      pointer-events: auto;
      cursor: crosshair;
    }

    .cake-sparkles {
      position: absolute;
      inset: -15%;
      pointer-events: none;
      opacity: .85;
      background:
        radial-gradient(circle at 18% 28%, rgba(255,211,106,.9) 0 2px, transparent 3px),
        radial-gradient(circle at 82% 32%, rgba(255,255,255,.8) 0 2px, transparent 3px),
        radial-gradient(circle at 70% 70%, rgba(255,95,159,.8) 0 2px, transparent 3px),
        radial-gradient(circle at 33% 75%, rgba(124,60,255,.85) 0 2px, transparent 3px);
      filter: drop-shadow(0 0 8px rgba(255,211,106,.6));
      animation: twinkle 2s ease-in-out infinite alternate;
    }

    @keyframes twinkle {
      from { opacity: .45; transform: scale(.98); }
      to { opacity: .95; transform: scale(1.02); }
    }

    .cake {
      position: absolute;
      left: 50%;
      bottom: 14px;
      width: 100%;
      height: 72%;
      transform: translateX(-50%);
      transform-style: preserve-3d;
    }

    .cake-layer {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      border-radius: 44px 44px 22px 22px;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(255,255,255,.88), transparent 20%),
        repeating-linear-gradient(90deg, rgba(255,255,255,.2) 0 5px, transparent 5px 34px),
        linear-gradient(180deg, #fff4d2 0%, #fbd3b1 40%, #d56b83 100%);
      border: 1px solid rgba(255,255,255,.5);
      box-shadow:
        inset 0 -16px 22px rgba(82,18,34,.18),
        inset 0 6px 14px rgba(255,255,255,.44),
        0 14px 28px rgba(0,0,0,.25);
      overflow: hidden;
    }

    .cake-layer::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 32%;
      border-radius: 50% / 42%;
      background:
        radial-gradient(circle at 14% 50%, #fffaf0 0 10px, transparent 11px),
        radial-gradient(circle at 34% 50%, #fffaf0 0 13px, transparent 14px),
        radial-gradient(circle at 55% 50%, #fffaf0 0 11px, transparent 12px),
        radial-gradient(circle at 76% 50%, #fffaf0 0 14px, transparent 15px),
        radial-gradient(circle at 92% 50%, #fffaf0 0 10px, transparent 11px),
        linear-gradient(180deg, #fffdf2, #ffe4bb);
      box-shadow: inset 0 -6px 10px rgba(255, 187, 104, .34);
    }

    .cake-layer::after {
      content: "";
      position: absolute;
      left: 9%;
      right: 9%;
      bottom: 12px;
      height: 16px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 8px 8px, #ff5f9f 0 5px, transparent 6px) 0 0/34px 16px,
        linear-gradient(90deg, rgba(255,211,106,.55), rgba(255,255,255,.4), rgba(255,211,106,.55));
    }

    .layer-bottom {
      bottom: 0;
      width: 92%;
      height: 42%;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(255,255,255,.75), transparent 20%),
        linear-gradient(180deg, #fff0d0 0%, #f7b489 42%, #9c2742 100%);
    }

    .layer-mid {
      bottom: 36%;
      width: 74%;
      height: 34%;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(255,255,255,.8), transparent 20%),
        linear-gradient(180deg, #fff8dd 0%, #fbd2ab 44%, #cf496e 100%);
    }

    .layer-top {
      bottom: 66%;
      width: 52%;
      height: 28%;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(255,255,255,.9), transparent 20%),
        linear-gradient(180deg, #fffceb 0%, #ffe0ad 46%, #d15c7c 100%);
    }

    .cake-title {
      position: absolute;
      left: 50%;
      bottom: 22%;
      width: 74%;
      transform: translateX(-50%);
      z-index: 3;
      text-align: center;
      font-family: Georgia, "Times New Roman", serif;
      font-weight: 900;
      font-size: clamp(1.05rem, 3.5vw, 1.8rem);
      line-height: 1.05;
      color: #641025;
      text-shadow: 0 1px 0 rgba(255,255,255,.48), 0 0 10px rgba(255,211,106,.24);
    }

    .candles {
      position: absolute;
      left: 50%;
      bottom: 92%;
      z-index: 4;
      width: 46%;
      height: 70px;
      transform: translateX(-50%);
      display: flex;
      align-items: end;
      justify-content: space-around;
    }

    .candle {
      position: relative;
      width: 13px;
      height: 52px;
      border-radius: 7px 7px 3px 3px;
      background: repeating-linear-gradient(135deg, #fff8d9 0 8px, #ff84ac 8px 15px);
      box-shadow: inset 0 0 7px rgba(0,0,0,.13);
    }

    .flame {
      position: absolute;
      left: 50%;
      top: -24px;
      width: 18px;
      height: 26px;
      transform: translateX(-50%);
      border-radius: 50% 50% 46% 46%;
      background: radial-gradient(circle at 50% 70%, #fff, #ffd36a 30%, #ff8b42 62%, transparent 68%);
      filter: drop-shadow(0 0 10px #ffd36a);
      animation: flameFlicker .9s ease-in-out infinite alternate;
      transform-origin: 50% 100%;
    }

    @keyframes flameFlicker {
      0% { transform: translateX(-50%) rotate(-3deg) scale(1); opacity: .9; }
      100% { transform: translateX(-50%) rotate(4deg) scale(1.13, .92); opacity: 1; }
    }

    .cake-cut-glow {
      position: absolute;
      left: 50%;
      bottom: 9%;
      width: 5px;
      height: 76%;
      z-index: 7;
      border-radius: 999px;
      opacity: 0;
      transform: translateX(-50%) rotate(31deg);
      background: linear-gradient(180deg, transparent, #fff, var(--gold), transparent);
      box-shadow: 0 0 18px rgba(255,255,255,.95), 0 0 30px rgba(255,211,106,.75);
      pointer-events: none;
    }

    .cake-slice {
      position: absolute;
      right: 14%;
      bottom: 13%;
      z-index: 6;
      width: 28%;
      height: 52%;
      clip-path: polygon(0 16%, 100% 0, 100% 100%, 12% 84%);
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.35), transparent 18%),
        linear-gradient(135deg, #fff3cc 0%, #f8bd90 52%, #a42b49 100%);
      border: 1px solid rgba(255,255,255,.35);
      box-shadow: 0 18px 30px rgba(0,0,0,.25), inset 0 0 16px rgba(255,255,255,.2);
      opacity: 0;
      transform: translate(0, 0) rotate(0deg);
      pointer-events: none;
    }

    .crumbs {
      position: absolute;
      inset: 0;
      z-index: 8;
      pointer-events: none;
    }

    .crumb {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--gold);
      opacity: 0;
      box-shadow: 0 0 12px rgba(255,211,106,.75);
    }

    .letter {
      position: absolute;
      right: clamp(6px, 8vw, 72px);
      bottom: clamp(30px, 11vw, 95px);
      z-index: 32;
      width: clamp(92px, 17vw, 142px);
      height: clamp(64px, 11vw, 98px);
      opacity: 0;
      transform: translateY(30px) rotate(8deg) scale(.92);
      pointer-events: none;
      cursor: pointer;
      filter: drop-shadow(0 18px 20px rgba(0,0,0,.36));
    }

    .letter.ready {
      pointer-events: auto;
    }

    .letter-body {
      position: absolute;
      inset: 0;
      border-radius: 10px;
      background:
        linear-gradient(135deg, #fff8dc, #f4d08c),
        repeating-linear-gradient(0deg, transparent 0 12px, rgba(128,84,32,.09) 12px 13px);
      border: 1px solid rgba(255,255,255,.8);
      box-shadow: inset 0 0 18px rgba(255,255,255,.48), 0 0 26px rgba(255,211,106,.25);
      overflow: hidden;
    }

    .letter-body::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(28deg, transparent 49%, rgba(150,87,34,.16) 50%, transparent 51%),
        linear-gradient(-28deg, transparent 49%, rgba(150,87,34,.16) 50%, transparent 51%);
    }

    .letter-seal {
      position: absolute;
      left: 50%;
      top: 52%;
      width: 28px;
      height: 28px;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      background: radial-gradient(circle, #ff9bbf, #941732 65%, #5d0817);
      box-shadow: 0 0 18px rgba(255,95,159,.55), inset 0 1px 0 rgba(255,255,255,.45);
    }

    .letter-hint {
      position: absolute;
      left: 50%;
      top: calc(100% + 12px);
      transform: translateX(-50%);
      white-space: nowrap;
      color: var(--gold-soft);
      font-size: clamp(.72rem, 2vw, .84rem);
      font-weight: 800;
      opacity: .86;
      text-shadow: 0 0 12px rgba(255,211,106,.45);
    }

    .letter:hover {
      animation: letterWiggle .7s ease-in-out infinite alternate;
      filter: drop-shadow(0 18px 20px rgba(0,0,0,.36)) drop-shadow(0 0 18px rgba(255,211,106,.42));
    }

    @keyframes letterWiggle {
      to { transform: translateY(18px) rotate(-4deg) scale(1.03); }
    }

    .knife {
      position: absolute;
      left: clamp(8px, 8vw, 82px);
      bottom: clamp(44px, 12vw, 110px);
      z-index: 27;
      width: clamp(150px, 28vw, 230px);
      height: 46px;
      opacity: 0;
      transform: translateY(35px) rotate(-16deg) scale(.92);
      pointer-events: none;
      cursor: pointer;
      filter: drop-shadow(0 14px 18px rgba(0,0,0,.44));
    }

    .knife.enabled {
      pointer-events: auto;
    }

    .knife .blade {
      position: absolute;
      right: 0;
      top: 7px;
      width: 70%;
      height: 24px;
      border-radius: 0 20px 20px 4px;
      clip-path: polygon(0 0, 100% 50%, 0 100%);
      background: linear-gradient(180deg, #fff, #b9becb 48%, #eef2ff 55%, #7e8493);
      box-shadow: inset 0 2px 2px rgba(255,255,255,.9), 0 0 20px rgba(255,255,255,.25);
    }

    .knife .handle {
      position: absolute;
      left: 0;
      top: 11px;
      width: 39%;
      height: 20px;
      border-radius: 999px;
      background: linear-gradient(135deg, #261014, #5b1120 55%, #14080a);
      border: 1px solid rgba(255,211,106,.4);
      box-shadow: inset 0 2px 4px rgba(255,255,255,.13);
    }

    .knife:hover {
      transform: translateY(25px) rotate(-10deg) scale(1.04);
      filter: drop-shadow(0 14px 18px rgba(0,0,0,.44)) drop-shadow(0 0 18px rgba(255,255,255,.4));
    }

    .cut-instruction {
      position: absolute;
      left: 50%;
      bottom: 4%;
      z-index: 31;
      transform: translateX(-50%) translateY(18px);
      opacity: 0;
      padding: 11px 18px;
      border-radius: 999px;
      background: rgba(8, 4, 10, .65);
      border: 1px solid rgba(255,255,255,.16);
      color: var(--gold-soft);
      font-size: .92rem;
      font-weight: 800;
      backdrop-filter: blur(12px);
      box-shadow: 0 10px 30px rgba(0,0,0,.35);
      pointer-events: none;
      white-space: nowrap;
    }

    .birthday-title {
      position: absolute;
      left: 50%;
      top: 15%;
      z-index: 40;
      width: min(96vw, 1020px);
      transform: translate(-50%, -20px) scale(.88);
      opacity: 0;
      text-align: center;
      font-size: clamp(2rem, 7vw, 6rem);
      line-height: .98;
      font-weight: 1000;
      letter-spacing: -.06em;
      background: linear-gradient(90deg, #fff7d7, #ffd36a 28%, #ff66a9 60%, #cbb3ff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 36px rgba(255,211,106,.35), 0 12px 80px rgba(255,95,159,.14);
      pointer-events: none;
    }

    .flash {
      position: fixed;
      inset: 0;
      z-index: 85;
      pointer-events: none;
      opacity: 0;
      background: radial-gradient(circle, rgba(255,255,255,.95), rgba(255,211,106,.32) 28%, transparent 62%);
      mix-blend-mode: screen;
    }

    /* =========================
       Letter Modal
    ========================== */
    .letter-modal {
      position: fixed;
      inset: 0;
      z-index: 90;
      display: grid;
      place-items: center;
      padding: 20px;
      background: rgba(0,0,0,.48);
      opacity: 0;
      pointer-events: none;
      backdrop-filter: blur(10px);
      transition: opacity .4s ease;
    }

    .letter-modal.open {
      opacity: 1;
      pointer-events: auto;
    }

    .letter-paper {
      width: min(760px, 94vw);
      max-height: min(82vh, 720px);
      overflow: auto;
      padding: clamp(24px, 5vw, 48px);
      border-radius: 28px;
      color: #412411;
      background:
        radial-gradient(circle at 20% 12%, rgba(255,255,255,.88), transparent 18%),
        repeating-linear-gradient(0deg, transparent 0 31px, rgba(122,76,34,.08) 31px 32px),
        linear-gradient(135deg, #fff7df, #f0c982 100%);
      border: 1px solid rgba(255,255,255,.78);
      box-shadow: 0 34px 90px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.8);
      transform: rotateX(18deg) scale(.86);
      opacity: 0;
      transform-origin: center top;
    }

    .letter-paper h2 {
      margin: 0 0 18px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.55rem, 5vw, 2.9rem);
      color: #7a1729;
      letter-spacing: -.03em;
    }

    .letter-paper p {
      margin: 0 0 16px;
      font-size: clamp(.96rem, 2.3vw, 1.12rem);
      line-height: 1.75;
      color: rgba(65,36,17,.92);
    }

    .typed-line {
      opacity: 0;
      transform: translateY(8px);
    }

    .modal-actions {
      margin-top: 26px;
      display: flex;
      justify-content: center;
    }

    /* =========================
       Vinyl Scene - Premium Turntable
    ========================== */
    .vinyl-scene {
      overflow: hidden;
      background:
        radial-gradient(circle at 50% 46%, rgba(255, 211, 106, .18), transparent 28%),
        radial-gradient(circle at 18% 22%, rgba(124, 60, 255, .28), transparent 24%),
        radial-gradient(circle at 82% 68%, rgba(255, 95, 159, .16), transparent 28%),
        linear-gradient(180deg, #0b0610 0%, #030204 100%);
    }

    .vinyl-scene::before {
      content: "";
      position: absolute;
      inset: -20%;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 16% 22%, rgba(255, 211, 106, .22) 0 8px, transparent 9px),
        radial-gradient(circle at 72% 18%, rgba(255, 255, 255, .16) 0 6px, transparent 7px),
        radial-gradient(circle at 82% 78%, rgba(124, 60, 255, .22) 0 10px, transparent 11px),
        radial-gradient(circle at 36% 80%, rgba(255, 95, 159, .14) 0 9px, transparent 10px);
      filter: blur(1px);
      opacity: .78;
      animation: bokehDrift 15s ease-in-out infinite alternate;
    }

    .vinyl-scene::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background:
        linear-gradient(115deg, transparent 0 36%, rgba(255, 255, 255, .05) 45%, transparent 56%),
        radial-gradient(ellipse at 50% 20%, rgba(255, 211, 106, .12), transparent 46%);
      mix-blend-mode: screen;
      animation: roomLightSweep 8s ease-in-out infinite;
    }

    @keyframes bokehDrift {
      from { transform: translate3d(-1.5%, -1%, 0) scale(1); }
      to { transform: translate3d(1.5%, 1.2%, 0) scale(1.05); }
    }

    @keyframes roomLightSweep {
      0%, 18% { opacity: .2; transform: translateX(-8%); }
      45% { opacity: .62; }
      100% { opacity: .28; transform: translateX(8%); }
    }

    .vinyl-room {
      position: relative;
      z-index: 5;
      width: min(1120px, 96vw);
      min-height: min(740px, 88vh);
      display: grid;
      place-items: center;
      perspective: 1200px;
      padding: clamp(26px, 4vw, 48px) 0 clamp(118px, 16vh, 158px);
      pointer-events: none;
    }

    .record-player {
      position: relative;
      width: min(850px, 92vw);
      height: clamp(390px, 54vw, 560px);
      transform-style: preserve-3d;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .vinyl-glow {
      position: absolute;
      left: 10%;
      top: 0;
      width: min(520px, 60vw);
      height: min(520px, 60vw);
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(255, 211, 106, .24), rgba(124, 60, 255, .13) 42%, transparent 72%);
      filter: blur(18px);
      opacity: .55;
      transform: translateZ(-30px);
      animation: glowBreathe 3.8s ease-in-out infinite alternate;
      pointer-events: none;
    }

    .vinyl-scene.music-on .vinyl-glow {
      opacity: .95;
      animation-duration: 1.8s;
    }

    @keyframes glowBreathe {
      to { transform: translateZ(-30px) scale(1.08); }
    }

    .turntable-base {
      position: absolute;
      left: 50%;
      top: 50%;
      width: min(790px, 92vw);
      height: clamp(300px, 42vw, 430px);
      transform: translate(-50%, -44%) rotateX(7deg);
      border-radius: clamp(28px, 4vw, 46px);
      overflow: hidden;
      background:
        linear-gradient(130deg, rgba(255,255,255,.14), transparent 19%, rgba(255,211,106,.12) 32%, transparent 48%),
        repeating-linear-gradient(90deg, rgba(255,255,255,.035) 0 2px, transparent 2px 46px),
        linear-gradient(135deg, #17070b 0%, #3a1217 42%, #090608 100%);
      border: 2px solid rgba(255, 211, 106, .42);
      box-shadow:
        0 48px 110px rgba(0,0,0,.72),
        inset 0 1px 0 rgba(255,255,255,.25),
        inset 0 -28px 50px rgba(0,0,0,.56),
        0 0 60px rgba(255,211,106,.13);
      pointer-events: none;
    }

    .turntable-base::before {
      content: "";
      position: absolute;
      inset: 14px;
      border-radius: calc(clamp(28px, 4vw, 46px) - 12px);
      border: 1px solid rgba(255,255,255,.11);
      background:
        radial-gradient(circle at 24% 42%, rgba(255,255,255,.08), transparent 30%),
        linear-gradient(180deg, rgba(255,255,255,.065), rgba(255,255,255,.018));
      box-shadow: inset 0 0 44px rgba(255,255,255,.04);
    }

    .base-reflection {
      position: absolute;
      inset: -20% -55%;
      z-index: 2;
      pointer-events: none;
      background: linear-gradient(100deg, transparent 28%, rgba(255,255,255,.17) 44%, rgba(255,211,106,.11) 50%, transparent 62%);
      transform: translateX(-38%) rotate(8deg);
      animation: baseReflection 8.5s ease-in-out infinite;
      mix-blend-mode: screen;
    }

    @keyframes baseReflection {
      0%, 25% { transform: translateX(-45%) rotate(8deg); opacity: 0; }
      42% { opacity: .8; }
      74%, 100% { transform: translateX(45%) rotate(8deg); opacity: 0; }
    }

    .platter {
      position: absolute;
      left: 8.5%;
      top: 50%;
      z-index: 4;
      width: min(455px, 53vw);
      aspect-ratio: 1 / 1;
      transform: translateY(-50%);
      border-radius: 50%;
      background:
        radial-gradient(circle, #08080b 0 58%, #b58a3a 59% 61%, #1e1515 62% 72%, #e7c56a 73% 74%, #09080b 75%);
      border: 2px solid rgba(255, 227, 148, .58);
      box-shadow:
        0 34px 60px rgba(0,0,0,.48),
        inset 0 0 30px rgba(255,255,255,.05),
        inset 0 0 0 9px rgba(255,211,106,.05);
      display: grid;
      place-items: center;
      will-change: transform;
      pointer-events: none;
    }

    .platter::after {
      content: "";
      position: absolute;
      inset: 6%;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,.09);
      box-shadow: inset 0 0 30px rgba(255,255,255,.035);
    }

    .platter-ring {
      position: absolute;
      inset: 1.8%;
      border-radius: 50%;
      border: 2px dashed rgba(255,211,106,.25);
      filter: drop-shadow(0 0 10px rgba(255,211,106,.14));
      animation: recordSpin 16s linear infinite;
      animation-play-state: paused;
    }

    .vinyl-scene.music-on .platter-ring {
      animation-play-state: running;
    }

    .vinyl-disc {
      position: relative;
      z-index: 5;
      width: 85%;
      height: 85%;
      border-radius: 50%;
      background:
        radial-gradient(circle at 50% 50%, transparent 0 19%, rgba(255,255,255,.035) 19.2% 20%, transparent 20.2% 100%),
        repeating-radial-gradient(circle, #060508 0 5px, #191319 5px 7px, #050406 7px 13px),
        conic-gradient(from 25deg, rgba(255,255,255,.14), transparent 10%, rgba(255,211,106,.18) 18%, transparent 31%, rgba(124,60,255,.14) 44%, transparent 62%, rgba(255,255,255,.1) 72%, transparent 100%);
      border: 2px solid rgba(255, 211, 106, .45);
      box-shadow:
        0 30px 70px rgba(0,0,0,.72),
        inset 0 0 48px rgba(255,255,255,.045),
        inset 0 0 0 8px rgba(255,211,106,.045),
        0 0 34px rgba(255,211,106,.18);
      animation: recordSpin 5.4s linear infinite;
      animation-play-state: paused;
      will-change: transform;
      pointer-events: none;
    }

    .vinyl-disc.playing {
      animation-play-state: running;
      animation-duration: 4.2s;
    }

    .vinyl-disc.slow {
      animation-play-state: running;
      animation-duration: 26s;
