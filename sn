    .spindle {
      position: absolute;
      left: 50%;
      top: 50%;
      z-index: 10;
      width: clamp(12px, 2vw, 18px);
      height: clamp(12px, 2vw, 18px);
      transform: translate(-50%, -50%);
      border-radius: 50%;
      background: radial-gradient(circle at 34% 28%, #fff7c7, #d69a2d 45%, #4a2c0d 100%);
      box-shadow: 0 0 16px rgba(255,211,106,.55), inset 0 1px 0 rgba(255,255,255,.72);
      pointer-events: none;
    }

    .tonearm-system {
      position: absolute;
      right: 6%;
      top: 9%;
      z-index: 9;
      width: 40%;
      height: 63%;
      pointer-events: none;
    }

    .tonearm-pivot {
      position: absolute;
      right: 3%;
      top: 1%;
      width: clamp(58px, 8vw, 82px);
      height: clamp(58px, 8vw, 82px);
      border-radius: 50%;
      background:
        radial-gradient(circle at 36% 28%, rgba(255,255,255,.74), transparent 17%),
        radial-gradient(circle, #f6d777 0 18%, #7a5521 46%, #16100e 76%);
      border: 2px solid rgba(255, 211, 106, .38);
      box-shadow: 0 16px 30px rgba(0,0,0,.45), inset 0 3px 5px rgba(255,255,255,.24), 0 0 28px rgba(255,211,106,.18);
    }

    .tonearm {
      position: absolute;
      right: calc(3% + clamp(29px, 4vw, 41px));
      top: calc(1% + clamp(29px, 4vw, 41px));
      z-index: 10;
      width: min(330px, 40vw);
      height: 112px;
      transform-origin: 100% 14%;
      transform: rotate(-24deg);
      transition: transform .9s cubic-bezier(.2,.9,.2,1), filter .5s ease;
      will-change: transform;
      filter: drop-shadow(0 14px 16px rgba(0,0,0,.45));
      pointer-events: none;
    }

    .vinyl-scene.tonearm-on .tonearm {
      transform: rotate(17deg);
      filter: drop-shadow(0 14px 16px rgba(0,0,0,.45)) drop-shadow(0 0 10px rgba(255,211,106,.18));
    }

    .vinyl-scene.music-off .tonearm {
      transform: rotate(9deg) translateY(-4px);
    }

    .tonearm-counterweight {
      position: absolute;
      right: -38px;
      top: -7px;
      width: clamp(42px, 5.6vw, 62px);
      height: clamp(28px, 3.8vw, 40px);
      border-radius: 999px;
      background: linear-gradient(135deg, #f2d78f, #6c552a 54%, #21180e);
      border: 1px solid rgba(255,255,255,.22);
      box-shadow: inset 0 2px 0 rgba(255,255,255,.35), 0 8px 14px rgba(0,0,0,.35);
    }

    .tonearm-bar {
      position: absolute;
      right: 22px;
      top: 13px;
      width: 86%;
      height: 12px;
      border-radius: 999px;
      transform: rotate(22deg);
      transform-origin: right center;
      background:
        linear-gradient(180deg, rgba(255,255,255,.7), transparent 35%),
        linear-gradient(90deg, #fff0b7 0%, #a99155 42%, #ede7d4 72%, #766039 100%);
      box-shadow: inset 0 -2px 2px rgba(0,0,0,.18), 0 0 14px rgba(255,211,106,.16);
    }

    .tonearm-bar::after {
      content: "";
      position: absolute;
      left: -18px;
      top: 2px;
      width: 34px;
      height: 8px;
      border-radius: 999px;
      background: linear-gradient(90deg, #bd9d59, #fff4c8);
      transform: rotate(10deg);
    }

    .headshell {
      position: absolute;
      left: 0;
      top: 48px;
      width: clamp(54px, 7vw, 74px);
      height: clamp(34px, 4.5vw, 46px);
