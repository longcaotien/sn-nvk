      knife: $("#knife"),
      cutInstruction: $("#cutInstruction"),
      birthdayTitle: $("#birthdayTitle"),
      flash: $("#flash"),
      vinyl: $("#vinyl"),
      recordPlayer: $("#recordPlayer"),
      turntableBase: $("#turntableBase"),
      platter: $("#platter"),
      vinylGlow: $("#vinylGlow"),
      soundWaves: $("#soundWaves"),
      tonearm: $("#tonearm"),
      ledLight: $("#ledLight"),
      equalizer: $("#equalizer"),
      musicNotes: $("#musicNotes"),
      restartBtn: $("#restartBtn"),
      bgMusic: $("#bgMusic")
    };

    const state = {
      started: false,
      cakeRevealed: false,
      letterOpened: false,
      knifeReady: false,
      knifeHeld: false,
      cakeCut: false,
      cakeCutting: false,
      closing: false,
      currentScene: "loading",
      musicEnabled: true,
      usingHowler: false,
      sound: null,
      loadingFinished: false,
      fallbackTimers: []
    };

    const SCENES = {
      loading: els.loadingScene,
      start: els.startScene,
      stage: els.stageScene,
      vinyl: els.vinylScene
    };

    const timelines = {
      loading: null,
      stage: null,
      cart: null,
      reveal: null,
      letter: null,
      knife: null,
      cut: null,
      fireworks: null,
      curtain: null,
      vinyl: null
    };

    /* =========================
       Helpers
    ========================== */
    function showScene(sceneNameOrEl) {
      const sceneEl = typeof sceneNameOrEl === "string" ? SCENES[sceneNameOrEl] : sceneNameOrEl;
      if (!sceneEl) {
        console.warn("Không tìm thấy scene cần hiển thị:", sceneNameOrEl);
        return;
      }

      Object.entries(SCENES).forEach(([name, scene]) => {
        const active = scene === sceneEl;
        scene.classList.toggle("active", active);
        scene.setAttribute("aria-hidden", active ? "false" : "true");
        scene.style.pointerEvents = active ? "auto" : "none";
      });
    }

    function killManagedAnimations() {
      if (!hasGSAP) return;
      Object.keys(timelines).forEach((key) => {
        if (timelines[key] && typeof timelines[key].kill === "function") {
          timelines[key].kill();
        }
        timelines[key] = null;
      });

      const targets = [
        els.loadingProgress, els.curtainLeft, els.curtainRight, els.cartWrap, els.mysteryCloth,
        els.cakeWrapper, els.letter, els.knife, els.cutInstruction, els.birthdayTitle,
        els.cakeCutGlow, els.cakeSlice, els.letterPaper, els.stageBackdrop, els.tonearm,
        els.recordPlayer, els.turntableBase, els.vinyl, els.platter, els.vinylGlow,
        ".wheel", ".crumb", ".typed-line", ".vinyl-copy", ".eq-bar", ".music-note"
      ];
      gsap.killTweensOf(targets);
    }

    function safeSet(el, props) {
      if (!el) return;
      Object.assign(el.style, props);
    }

    function animate(target, vars, fallback = null) {
      if (hasGSAP) return gsap.to(target, vars);
      if (fallback) fallback();
      return null;
    }

    function fromTo(target, fromVars, toVars, fallback = null) {
      if (hasGSAP) return gsap.fromTo(target, fromVars, toVars);
      if (fallback) fallback();
      return null;
    }

    function delay(ms, fn) {
      const id = setTimeout(fn, ms);
      state.fallbackTimers.push(id);
      return id;
    }

    function clearTimers() {
      state.fallbackTimers.forEach(clearTimeout);
      state.fallbackTimers = [];
    }

    function clamp(n, min, max) {
      return Math.max(min, Math.min(max, n));
    }

    function scenePoint(el) {
      const rect = el.getBoundingClientRect();
      return {
        x: (rect.left + rect.width / 2) / window.innerWidth,
        y: (rect.top + rect.height / 2) / window.innerHeight
      };
    }

    function createCrumbs() {
      if (!els.crumbs) return;
      els.crumbs.innerHTML = "";
      const colors = ["#ffd36a", "#fff6dc", "#ff8fb9", "#f2b06f", "#ffffff", "#bda5ff"];
      for (let i = 0; i < 34; i++) {
        const c = document.createElement("span");
        c.className = "crumb";
        c.style.left = `${42 + Math.random() * 24}%`;
        c.style.top = `${25 + Math.random() * 46}%`;
        c.style.background = colors[i % colors.length];
        c.style.width = `${4 + Math.random() * 7}px`;
        c.style.height = c.style.width;
        els.crumbs.appendChild(c);
      }

      if (els.creamParticles) {
        els.creamParticles.innerHTML = "";
        for (let i = 0; i < 18; i++) {
          const drop = document.createElement("span");
          drop.className = "cream-drop";
          drop.style.left = `${46 + Math.random() * 18}%`;
          drop.style.top = `${32 + Math.random() * 36}%`;
          drop.style.animationDelay = `${Math.random() * .25}s`;
          els.creamParticles.appendChild(drop);
        }
      }
    }

    function setFlowStep(step) {
      if (!els.flowSteps) return;
      els.flowSteps.classList.toggle("knife-ready", step >= 2);
      els.flowSteps.classList.toggle("cut-ready", step >= 3);
      if (els.stepKnife) els.stepKnife.classList.toggle("done", step >= 2);
      if (els.stepCut) els.stepCut.classList.toggle("done", step >= 3);
    }

    /* =========================
       Music with Howler fallback
    ========================== */
    function initMusic() {
      if (hasHowler) {
        try {
          state.sound = new Howl({
            src: [MUSIC_SRC],
            loop: true,
            volume: 0.55,
            html5: true,
            onloaderror: () => console.info("Không tìm thấy file nhạc. Hãy thay your-music.mp3 bằng file của bạn."),
            onplayerror: () => console.info("Trình duyệt cần thao tác người dùng trước khi phát nhạc.")
          });
          state.usingHowler = true;
        } catch (err) {
          state.usingHowler = false;
        }
      }
    }

    function playMusic() {
      state.musicEnabled = true;
      els.musicIcon.textContent = "♪";
      els.musicToggle.classList.add("visible");
      if (state.usingHowler && state.sound) {
        try {
          if (!state.sound.playing()) state.sound.play();
        } catch (err) {}
      } else if (els.bgMusic) {
        els.bgMusic.volume = 0.55;
        els.bgMusic.play().catch(() => console.info("Không tìm thấy hoặc chưa cho phép phát file nhạc."));
      }
      updateVinylByMusic();
    }

    function pauseMusic() {
      state.musicEnabled = false;
      els.musicIcon.textContent = "✕";
      if (state.usingHowler && state.sound) {
        try { state.sound.pause(); } catch (err) {}
      } else if (els.bgMusic) {
        els.bgMusic.pause();
      }
      updateVinylByMusic();
    }

    function toggleMusic() {
      if (state.musicEnabled) pauseMusic();
      else playMusic();
    }

    function updateVinylByMusic() {
      const inVinyl = state.currentScene === "vinyl";
      const musicOn = Boolean(inVinyl && state.musicEnabled);

      if (!els.vinylScene || !els.vinyl) return;

      els.vinylScene.classList.toggle("music-on", musicOn);
      els.vinylScene.classList.toggle("music-off", inVinyl && !state.musicEnabled);
      els.vinylScene.classList.toggle("tonearm-on", inVinyl);

      els.vinyl.classList.toggle("playing", musicOn);
      els.vinyl.classList.toggle("slow", inVinyl && !state.musicEnabled);
      if (!inVinyl) {
        els.vinyl.classList.remove("playing", "slow");
        els.vinylScene.classList.remove("music-on", "tonearm-on");
        els.vinylScene.classList.add("music-off");
      }

      safeSet(els.soundWaves, { opacity: musicOn ? "1" : "0" });
      safeSet(els.musicNotes, { opacity: musicOn ? "1" : "0" });
      safeSet(els.equalizer, { opacity: musicOn ? "1" : (inVinyl ? ".35" : "0") });
      safeSet(els.vinylGlow, { opacity: musicOn ? ".95" : (inVinyl ? ".55" : "0") });

      if (els.musicToggle) {
        els.musicToggle.setAttribute("aria-pressed", state.musicEnabled ? "true" : "false");
      }

      if (hasGSAP && inVinyl && els.tonearm) {
        gsap.to(els.tonearm, {
          rotation: musicOn ? 17 : 9,
          y: musicOn ? 0 : -4,
          duration: .65,
          ease: "power3.out",
          overwrite: "auto"
        });
      }
    }

    /* =========================
       Particles / Visual FX
    ========================== */
    function initParticles() {
      if (!hasParticles) {
        console.info("tsParticles không tải được, dùng nền CSS fallback.");
        return;
      }
      tsParticles.load("particles", {
        fpsLimit: 60,
        background: { color: "transparent" },
        particles: {
          number: { value: 76, density: { enable: true, area: 900 } },
          color: { value: ["#ffd36a", "#fff6dc", "#ff95c1", "#bda5ff"] },
          opacity: { value: { min: 0.12, max: 0.6 }, animation: { enable: true, speed: 0.45, minimumValue: 0.1 } },
          size: { value: { min: 1, max: 3.2 } },
          move: { enable: true, speed: 0.45, direction: "top", random: true, outModes: { default: "out" } },
          links: { enable: false }
        },
        detectRetina: true
      }).catch(() => {});

      tsParticles.load("vinylParticles", {
        fpsLimit: 60,
        background: { color: "transparent" },
        particles: {
          number: { value: 52, density: { enable: true, area: 900 } },
          color: { value: ["#ffd36a", "#7c3cff", "#fff6dc"] },
          opacity: { value: { min: 0.08, max: 0.46 } },
          size: { value: { min: 1, max: 3 } },
          move: { enable: true, speed: 0.38, direction: "none", random: true, outModes: { default: "bounce" } },
          links: { enable: true, distance: 110, color: "#ffd36a", opacity: 0.08, width: 1 }
        },
        detectRetina: true
      }).catch(() => {});
    }

    function burstFromCake() {
      if (!hasConfetti) return fallbackBurst();
      const origin = scenePoint(els.cakeWrapper);
      const colors = ["#ffd36a", "#ff315d", "#62ddff", "#8c5cff", "#ff8ac4", "#fff6dc"];

      confetti({
        particleCount: 90,
        spread: 78,
        startVelocity: 48,
        origin,
        colors,
        scalar: 1.05
      });

      delay(260, () => confetti({
        particleCount: 130,
        spread: 120,
        startVelocity: 58,
        origin,
        colors,
        shapes: ["star"],
        scalar: 1.18
      }));

      delay(650, () => confetti({
        particleCount: 120,
        spread: 150,
        startVelocity: 46,
        origin: { x: origin.x, y: clamp(origin.y - .08, .05, .9) },
        colors,
        scalar: .95
      }));

      const end = Date.now() + 3300;
      (function frame() {
        confetti({
          particleCount: 12,
          angle: 60,
          spread: 60,
          origin: { x: 0, y: .8 },
          colors,
          scalar: .8
        });
        confetti({
          particleCount: 12,
          angle: 120,
          spread: 60,
          origin: { x: 1, y: .8 },
          colors,
          scalar: .8
        });
        if (Date.now() < end) requestAnimationFrame(frame);
      })();
    }

    function fallbackBurst() {
      fromTo(els.flash, { opacity: 0 }, { opacity: .75, duration: .18, yoyo: true, repeat: 1 });
    }

    function addScreenShake() {
      els.app.classList.remove("screen-shake");
      void els.app.offsetWidth;
      els.app.classList.add("screen-shake");
      delay(700, () => els.app.classList.remove("screen-shake"));
    }

    function initParallax() {
      window.addEventListener("pointermove", (e) => {
        if (state.currentScene !== "stage") return;
        const x = (e.clientX / window.innerWidth - 0.5) * 2;
        const y = (e.clientY / window.innerHeight - 0.5) * 2;
        if (hasGSAP) {
          gsap.to(els.stageBackdrop, { x: x * 10, y: y * 6, duration: .8, ease: "power3.out" });
          gsap.to(els.cakeWrapper, { rotateY: x * 4, rotateX: y * -2, duration: .8, ease: "power3.out" });
        } else {
          els.stageBackdrop.style.transform = `translateX(calc(-50% + ${x * 10}px)) translateY(${y * 6}px) translateZ(-80px)`;
        }
      }, { passive: true });
    }

    /* =========================
       Main Timeline Functions
    ========================== */
    function showLoading() {
      state.currentScene = "loading";
      state.loadingFinished = false;
      showScene("loading");
      safeSet(els.loadingProgress, { width: "0%" });

      const finishLoading = () => {
        if (state.loadingFinished) return;
        state.loadingFinished = true;
        showStartScreen();
      };

      delay(2450, finishLoading);

      if (hasGSAP) {
        timelines.loading = gsap.to(els.loadingProgress, {
          width: "100%",
          duration: 2,
          ease: "power3.inOut",
          onComplete: finishLoading
        });
      } else {
        console.info("GSAP không tải được, dùng loading fallback bằng CSS/JS thuần.");
        els.loadingProgress.style.transition = "width 2s ease";
        requestAnimationFrame(() => els.loadingProgress.style.width = "100%");
      }
    }

    function showStartScreen() {
      state.currentScene = "start";
      showScene("start");
      els.startBtn.disabled = false;
      typeStartTitle();
    }

    function typeStartTitle() {
      const text = "Một món quà đặc biệt dành cho Nguyễn Văn Kiên...";
      els.typeText.textContent = "";
      let i = 0;
      const speed = 44;
      const tick = () => {
        els.typeText.textContent = text.slice(0, i++);
        if (i <= text.length) delay(speed, tick);
      };
      tick();
    }

    function startShow() {
      if (state.started) return;
      state.started = true;
      playMusic();
      state.currentScene = "stage";
      els.startBtn.disabled = true;
      resetStage(false);
      showScene("stage");

      if (hasGSAP) {
        timelines.stage = gsap.timeline({ defaults: { ease: "power3.out" } });
        timelines.stage.to([els.curtainLeft, els.curtainRight], {
          xPercent: (i) => i === 0 ? -86 : 86,
          duration: 1.6,
          ease: "expo.inOut"
        })
        .fromTo(els.stageBackdrop, { scale: .94, opacity: .65 }, { scale: 1, opacity: 1, duration: 1.1 }, "-=.9")
        .call(moveCart, [], "+=.28");
      } else {
        safeSet(els.curtainLeft, { transform: "translateX(-86%)" });
        safeSet(els.curtainRight, { transform: "translateX(86%) scaleX(-1)" });
        console.info("GSAP không tải được, dùng animation sân khấu fallback.");
        delay(800, moveCart);
      }
    }

    function moveCart() {
      const cartWidth = els.cartWrap.offsetWidth || 380;
      const startLeft = -cartWidth - 120;
      const targetX = (window.innerWidth - cartWidth) / 2 - startLeft;

      if (hasGSAP) {
        gsap.set(els.cartWrap, { left: startLeft, x: 0, y: 0, opacity: 1, scale: 1 });
        gsap.set(".cart-rope", { transformOrigin: "100% 50%" });
        timelines.cart = gsap.timeline({ defaults: { ease: "power2.inOut" } });
        timelines.cart
          .to(".cart-wheel", { rotation: 1320, duration: 3.15, ease: "none" }, 0)
          .to(els.cartWrap, { x: targetX, duration: 3.15, ease: "power2.inOut" }, 0)
          .to(els.cartWrap, { y: -7, duration: .18, yoyo: true, repeat: 15, ease: "sine.inOut" }, .08)
          .to(".cart-rope", { rotation: -4, scaleX: 1.06, duration: .24, yoyo: true, repeat: 10, ease: "sine.inOut" }, .18)
          .to(".cart-spark-trail, .stage-dust", { opacity: .95, duration: .5, stagger: .08 }, .2)
          .to(els.cartWrap, { y: -12, duration: .18, ease: "power2.out" })
          .to(els.cartWrap, { y: 0, duration: .38, ease: "bounce.out" })
          .call(revealCake);
      } else {
        safeSet(els.cartWrap, { left: `${startLeft}px`, transform: "translateX(0)", transition: "transform 3s ease" });
        requestAnimationFrame(() => safeSet(els.cartWrap, { transform: `translateX(${targetX}px)` }));
        delay(3200, revealCake);
      }
    }

    function revealCake() {
      if (state.cakeRevealed) return;
      state.cakeRevealed = true;

      if (hasGSAP) {
        if (timelines.reveal) timelines.reveal.kill();
        timelines.reveal = gsap.timeline({ defaults: { ease: "power3.out" } });
        timelines.reveal
          .to(els.mysteryCloth, {
            y: -168,
            scaleY: .34,
            scaleX: 1.18,
            rotation: -7,
            opacity: .12,
            duration: 1.08,
            ease: "back.in(1.35)"
          })
          .to(els.flash, { opacity: .68, duration: .13, yoyo: true, repeat: 1 }, "-=.48")
          .fromTo(els.cakeWrapper,
            { xPercent: -50, y: 165, scale: .72, opacity: 0, rotateY: -18, rotateX: 5 },
            { xPercent: -50, y: 0, scale: 1, opacity: 1, rotateY: 0, rotateX: 0, duration: 1.35, ease: "elastic.out(1, .62)" },
            "-=.55"
          )
          .fromTo(".cake-tier", { y: 32, opacity: .2, scale: .92 }, { y: 0, opacity: 1, scale: 1, duration: .78, stagger: .12, ease: "back.out(1.7)" }, "-=.92")
          .fromTo(".cake-topper, .name-plaque, .cherry, .sugar-star, .heart-deco, .flower-cream", { y: 10, opacity: 0, scale: .55 }, { y: 0, opacity: 1, scale: 1, duration: .58, stagger: .035, ease: "back.out(2)" }, "-=.45")
          .fromTo(".cake-sparkles", { opacity: 0, scale: .75 }, { opacity: 1, scale: 1, duration: .7, ease: "power3.out" }, "-=.55")
          .to(els.cartWrap, { x: window.innerWidth + 540, opacity: 0, duration: 1.45, ease: "power3.inOut" }, "+=.15")
          .add(() => {
            els.letter.classList.add("ready");
            setFlowStep(1);
          })
          .fromTo(els.letter, { y: 30, opacity: 0, scale: .82, rotation: 8 }, { y: 0, opacity: 1, scale: 1, rotation: -4, duration: .9, ease: "back.out(1.8)" }, "-=.52");
      } else {
        safeSet(els.mysteryCloth, { transform: "translateY(-168px) scaleY(.34)", opacity: ".12" });
        safeSet(els.cakeWrapper, { transform: "translateX(-50%) translateY(0) scale(1)", opacity: "1" });
        els.letter.classList.add("ready");
        setFlowStep(1);
        safeSet(els.letter, { opacity: "1", transform: "translateY(0) rotate(-4deg) scale(1)" });
      }
    }

    function openLetter() {
      if (!state.cakeRevealed || state.letterOpened || els.letterModal.classList.contains("open")) return;
      state.letterOpened = true;
      els.letterModal.classList.add("open");

      const lines = $$(".typed-line");
      if (hasGSAP) {
        gsap.set(lines, { opacity: 0, y: 10 });
        const tl = gsap.timeline();
        tl.fromTo(els.letterPaper,
          { rotateX: 24, scale: .84, opacity: 0, y: 30 },
          { rotateX: 0, scale: 1, opacity: 1, y: 0, duration: .75, ease: "back.out(1.4)" }
        ).to(lines, { opacity: 1, y: 0, duration: .62, stagger: .28, ease: "power3.out" }, "-=.2");
      } else {
        safeSet(els.letterPaper, { opacity: "1", transform: "rotateX(0) scale(1)" });
        lines.forEach(line => safeSet(line, { opacity: "1", transform: "none" }));
      }
    }

    function closeLetter() {
      if (!els.letterModal.classList.contains("open")) return;
      if (hasGSAP) {
        gsap.to(els.letterPaper, {
          rotateX: -12,
          scale: .88,
          opacity: 0,
          y: -16,
          duration: .35,
          ease: "power2.in",
          onComplete: () => {
            els.letterModal.classList.remove("open");
            prepareKnife();
          }
        });
      } else {
        els.letterModal.classList.remove("open");
        prepareKnife();
      }
    }

    function prepareKnife() {
      if (state.knifeReady) return;
      state.knifeReady = true;
      state.cakeCutting = false;
      els.letter.classList.remove("ready");
      els.knife.classList.add("enabled");
      setFlowStep(2);

      if (hasGSAP) {
        if (timelines.knife) timelines.knife.kill();
        timelines.knife = gsap.timeline({ defaults: { ease: "power3.out" } });
        timelines.knife
          .fromTo(els.knife,
            { y: 44, x: -18, opacity: 0, rotation: -26, scale: .82 },
            { y: 0, x: 0, opacity: 1, rotation: -16, scale: 1, duration: .92, ease: "back.out(1.7)" }
          );
      } else {
        safeSet(els.knife, { opacity: "1", transform: "translateY(0) rotate(-16deg) scale(1)" });
      }
    }

    function holdKnife() {
      if (!state.knifeReady || state.knifeHeld || state.cakeCut || state.cakeCutting) return;
      state.knifeHeld = true;
      els.knife.classList.add("enabled", "knife-held");
      els.cakeWrapper.classList.add("cut-ready", "cake-cut-ready");
      setFlowStep(3);

      if (hasGSAP) {
        gsap.to(els.knife, {
          x: window.innerWidth < 560 ? 74 : 122,
          y: window.innerWidth < 560 ? -76 : -92,
          rotation: 18,
          scale: 1.08,
          duration: .72,
          ease: "power3.out"
        });
        gsap.to(els.cutInstruction, { opacity: 1, y: 0, duration: .45, ease: "power3.out" });
        gsap.to(els.cutGuide, { opacity: .72, scaleY: 1, duration: .42, ease: "power3.out" });
      } else {
        safeSet(els.knife, { transform: "translate(115px, -75px) rotate(18deg) scale(1.08)", opacity: "1" });
        safeSet(els.cutInstruction, { opacity: "1", transform: "translateX(-50%) translateY(0)" });
        safeSet(els.cutGuide, { opacity: ".72" });
      }
    }

    function cutCake(event) {
      if (!state.knifeHeld || state.cakeCut || state.cakeCutting) return;
      state.cakeCutting = true;
      els.knife.classList.remove("enabled");
      els.cakeWrapper.classList.remove("cut-ready", "cake-cut-ready");
      createCrumbs();

      const crumbs = $$(".crumb");
      const creamDrops = $$(".cream-drop");

      if (hasGSAP) {
        if (timelines.cut) timelines.cut.kill();
        timelines.cut = gsap.timeline({ defaults: { ease: "power3.out" } });
        const knifeStart = window.innerWidth < 560 ? { x: 54, y: -132, rotation: 34 } : { x: 155, y: -146, rotation: 32 };
        const knifeEnd = window.innerWidth < 560 ? { x: 185, y: -24, rotation: 45 } : { x: 320, y: -18, rotation: 45 };

        timelines.cut
          .to(els.cutInstruction, { opacity: 0, y: 15, duration: .24 })
          .to(els.knife, { ...knifeStart, scale: 1.12, duration: .42, ease: "power2.out" }, 0)
          .to(els.cutGuide, { opacity: 1, scaleY: 1.05, duration: .2 }, "-=.1")
          .to(els.knife, { ...knifeEnd, duration: .82, ease: "power2.inOut" })
          .to(els.cakeWrapper, { x: -5, duration: .055, yoyo: true, repeat: 9 }, "-=.62")
          .fromTo(els.cakeCutGlow, { opacity: 0, scaleY: .2 }, { opacity: 1, scaleY: 1.18, duration: .28, yoyo: true, repeat: 1 }, "-=.58")
          .to(".tier-bottom, .tier-middle, .tier-top", { x: (i) => i === 0 ? -4 : i === 1 ? -2 : 0, duration: .22, yoyo: true, repeat: 1 }, "-=.44")
          .to(els.cakeSlice, { opacity: 1, x: window.innerWidth < 560 ? 28 : 54, y: 24, rotation: 10, scale: 1.04, duration: .72, ease: "back.out(1.45)" }, "-=.2")
          .to(crumbs, {
            opacity: 1,
            x: () => gsap.utils.random(-95, 140),
            y: () => gsap.utils.random(-100, 38),
            scale: () => gsap.utils.random(.45, 1.65),
            duration: .72,
            stagger: .01,
            ease: "power2.out"
          }, "-=.58")
          .to(creamDrops, {
            opacity: 1,
            x: () => gsap.utils.random(-60, 78),
            y: () => gsap.utils.random(28, 92),
            scaleY: () => gsap.utils.random(.7, 1.45),
            duration: .78,
            stagger: .018,
            ease: "bounce.out"
          }, "-=.52")
          .to(els.insideGlow, { opacity: .92, scale: 1.05, duration: .48, ease: "power2.out" }, "-=.12")
          .to(crumbs, { opacity: 0, y: "+=58", duration: .82, stagger: .008, ease: "power2.in" }, "+=.1")
          .to(creamDrops, { opacity: 0, duration: .38 }, "-=.3")
          .call(() => {
            state.cakeCut = true;
            delay(360, launchFireworks);
          });
      } else {
        state.cakeCut = true;
        safeSet(els.cutInstruction, { opacity: "0" });
        safeSet(els.cakeCutGlow, { opacity: "1" });
        safeSet(els.insideGlow, { opacity: ".9" });
        safeSet(els.cakeSlice, { opacity: "1", transform: "translate(36px,24px) rotate(10deg)" });
        delay(760, launchFireworks);
      }
    }

    function launchFireworks() {
      els.letter.classList.remove("ready");
      els.knife.classList.remove("enabled", "knife-held");
      els.cakeWrapper.classList.remove("cut-ready", "cake-cut-ready");
      addScreenShake();
      burstFromCake();

      if (hasGSAP) {
        const tl = gsap.timeline();
        tl.to(els.flash, { opacity: .88, duration: .14, yoyo: true, repeat: 1 })
          .fromTo(els.birthdayTitle,
            { opacity: 0, y: -20, scale: .82, filter: "blur(10px)" },
            { opacity: 1, y: 0, scale: 1, filter: "blur(0px)", duration: .82, ease: "back.out(1.6)" },
            "-=.1"
          )
          .to(els.birthdayTitle, { scale: 1.035, duration: .22, yoyo: true, repeat: 6, ease: "sine.inOut" })
          .to([els.birthdayTitle, els.cakeWrapper, els.letter, els.knife], { opacity: 0, duration: .95, ease: "power3.inOut" }, "+=2.35")
          .call(closeCurtain);
      } else {
        safeSet(els.birthdayTitle, { opacity: "1", transform: "translate(-50%, 0) scale(1)" });
        delay(4800, closeCurtain);
      }
    }

    function closeCurtain() {
      if (state.closing) return;
      state.closing = true;

      if (hasGSAP) {
        const tl = gsap.timeline({ defaults: { ease: "expo.inOut" } });
        tl.to([els.curtainLeft, els.curtainRight], {
          xPercent: 0,
          duration: 1.7
        })
        .to(els.stageScene, { filter: "blur(12px)", duration: .55, ease: "power2.out" }, "-=.45")
        .call(showVinylScene);
      } else {
        safeSet(els.curtainLeft, { transform: "translateX(0)" });
        safeSet(els.curtainRight, { transform: "translateX(0) scaleX(-1)" });
        delay(1800, showVinylScene);
      }
    }

    function showVinylScene() {
      state.currentScene = "vinyl";
      showScene("vinyl");

      if (timelines.vinyl && typeof timelines.vinyl.kill === "function") {
        timelines.vinyl.kill();
        timelines.vinyl = null;
      }

      els.vinylScene.classList.remove("music-on", "tonearm-on");
      els.vinylScene.classList.add("music-off");
      els.vinyl.classList.remove("playing", "slow");
      safeSet(els.soundWaves, { opacity: "0" });
      safeSet(els.musicNotes, { opacity: "0" });
      safeSet(els.equalizer, { opacity: "0" });

      if (hasGSAP) {
        gsap.set(els.stageScene, { clearProps: "filter" });
        gsap.set(els.vinylScene, { scale: 1.04, filter: "blur(10px)" });
        gsap.set(els.recordPlayer, { y: 76, opacity: 0, scale: .88, rotateX: 8 });
        gsap.set(els.turntableBase, { transformOrigin: "50% 50%", scale: .94 });
        gsap.set(els.vinyl, { rotation: -24, scale: .82 });
        gsap.set(els.tonearm, { rotation: -24, y: -12, transformOrigin: "100% 14%" });
        gsap.set(".vinyl-copy", { y: 24, opacity: 0 });
        gsap.set(".eq-bar", { scaleY: .28 });

        timelines.vinyl = gsap.timeline({
          defaults: { ease: "power3.out" },
          onComplete: updateVinylByMusic
        });

        timelines.vinyl
          .to(els.vinylScene, { scale: 1, filter: "blur(0px)", duration: .9, ease: "power3.out" })
          .to(els.recordPlayer, { y: 0, opacity: 1, scale: 1, rotateX: 0, duration: 1.05, ease: "back.out(1.35)" }, "-=.55")
          .to(els.vinyl, { rotation: 0, scale: 1, duration: .95, ease: "back.out(1.5)" }, "-=.72")
          .to(els.turntableBase, { scale: 1, duration: .8, ease: "power3.out" }, "-=.82")
          .to(els.tonearm, { rotation: 17, y: 0, duration: 1.05, ease: "power3.out" }, "-=.2")
          .to(els.tonearm, { y: -3, duration: .12, ease: "power1.out" })
          .to(els.tonearm, { y: 0, duration: .2, ease: "bounce.out" })
          .to(".vinyl-copy", { y: 0, opacity: 1, duration: .8, ease: "power3.out" }, "-=.55");
      } else {
        safeSet(els.recordPlayer, { opacity: "1", transform: "none" });
        safeSet(els.vinylScene, { filter: "blur(0)", transform: "scale(1)" });
        safeSet(els.tonearm, { transform: "rotate(17deg)" });
        updateVinylByMusic();
      }
    }

    function resetStage(full = true) {
      clearTimers();
      state.started = full ? false : state.started;
      state.cakeRevealed = false;
      state.letterOpened = false;
      state.knifeReady = false;
      state.knifeHeld = false;
      state.cakeCut = false;
      state.cakeCutting = false;
      state.closing = false;
      els.letterModal.classList.remove("open");
      els.letter.classList.remove("ready");
      els.knife.classList.remove("enabled", "knife-held");
      els.cakeWrapper.classList.remove("cut-ready", "cake-cut-ready");
      setFlowStep(0);
      els.vinylScene.classList.remove("music-on", "tonearm-on");
      els.vinylScene.classList.add("music-off");
      if (els.vinyl) els.vinyl.classList.remove("playing", "slow");
      createCrumbs();

      if (hasGSAP) {
        killManagedAnimations();
        gsap.set(els.loadingProgress, { width: full ? "0%" : "100%" });
        gsap.set(els.curtainLeft, { xPercent: 0, x: 0 });
        gsap.set(els.curtainRight, { xPercent: 0, x: 0, scaleX: -1 });
        gsap.set(els.cartWrap, { x: 0, y: 0, opacity: 1, left: -420 });
        gsap.set($$(".cart-wheel, .wheel"), { rotation: 0 });
        gsap.set(els.mysteryCloth, { clearProps: "transform,opacity" });
        gsap.set([".cart-spark-trail", ".stage-dust"], { clearProps: "opacity,transform" });
        gsap.set(els.cakeWrapper, { xPercent: -50, x: 0, y: 150, scale: .78, opacity: 0, rotateX: 0, rotateY: 0 });
        gsap.set(els.letter, { y: 30, opacity: 0, scale: .92, rotation: 8 });
        gsap.set(els.knife, { x: 0, y: 35, rotation: -16, scale: .92, opacity: 0 });
        gsap.set(els.cutInstruction, { opacity: 0, y: 18 });
        gsap.set(els.birthdayTitle, { opacity: 0, y: -20, scale: .88, filter: "blur(0px)" });
        gsap.set(els.cakeCutGlow, { opacity: 0, scaleY: 1 });
        if (els.cutGuide) gsap.set(els.cutGuide, { opacity: 0, scaleY: .7 });
        if (els.insideGlow) gsap.set(els.insideGlow, { opacity: 0, scale: .8 });
        gsap.set(els.cakeSlice, { opacity: 0, x: 0, y: 0, rotation: 0, scale: 1 });
        gsap.set(".cream-drop", { opacity: 0, x: 0, y: 0, scale: 1 });
        gsap.set(els.letterPaper, { opacity: 0, rotateX: 18, scale: .86, y: 0 });
        gsap.set(els.recordPlayer, { opacity: 1, y: 0, scale: 1, rotateX: 0 });
        gsap.set(els.vinyl, { rotation: 0, scale: 1 });
        gsap.set(els.tonearm, { rotation: -24, y: -12, transformOrigin: "100% 14%" });
        gsap.set([els.soundWaves, els.musicNotes, els.equalizer], { opacity: 0 });
        gsap.set(".vinyl-copy", { clearProps: "opacity,transform" });
      } else {
        safeSet(els.loadingProgress, { width: full ? "0%" : "100%" });
        safeSet(els.cartWrap, { left: "-420px", transform: "none", opacity: "1" });
        safeSet(els.cakeWrapper, { transform: "translateX(-50%) translateY(140px) scale(.8)", opacity: "0" });
        safeSet(els.letter, { opacity: "0", transform: "translateY(30px) rotate(8deg) scale(.92)" });
        safeSet(els.knife, { opacity: "0", transform: "translateY(35px) rotate(-16deg) scale(.92)" });
        safeSet(els.cutGuide, { opacity: "0" });
        safeSet(els.insideGlow, { opacity: "0" });
        safeSet(els.birthdayTitle, { opacity: "0" });
        safeSet(els.recordPlayer, { opacity: "1", transform: "none" });
        safeSet(els.soundWaves, { opacity: "0" });
        safeSet(els.musicNotes, { opacity: "0" });
        safeSet(els.equalizer, { opacity: "0" });
      }
    }

    function restartShow() {
      resetStage(true);
      state.currentScene = "loading";
      showScene("loading");
      pauseMusic();
      els.musicToggle.classList.remove("visible");
      els.startBtn.disabled = false;
      delay(250, showLoading);
    }

    /* =========================
       Event Bindings
    ========================== */
    function bindEvents() {
      els.startBtn.addEventListener("click", startShow);
      els.musicToggle.addEventListener("click", toggleMusic);
      els.letter.addEventListener("click", openLetter);
      els.letter.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          openLetter();
        }
      });
      els.closeLetterBtn.addEventListener("click", closeLetter);
      els.knife.addEventListener("click", holdKnife);
      els.knife.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          holdKnife();
        }
      });
      
      let cakePointerStart = null;
      els.cakeWrapper.addEventListener("pointerdown", (e) => {
        if (!state.knifeHeld || state.cakeCut || state.cakeCutting) return;
        cakePointerStart = { x: e.clientX, y: e.clientY, time: Date.now() };
      });
      els.cakeWrapper.addEventListener("pointerup", (e) => {
        if (!cakePointerStart || !state.knifeHeld || state.cakeCut || state.cakeCutting) return;
        const dx = Math.abs(e.clientX - cakePointerStart.x);
        const dy = Math.abs(e.clientY - cakePointerStart.y);
        if (dx + dy > 18 || Date.now() - cakePointerStart.time > 120) cutCake(e);
        cakePointerStart = null;
      });
      els.cakeWrapper.addEventListener("click", cutCake);
      els.restartBtn.addEventListener("click", restartShow);

      els.letterModal.addEventListener("click", (e) => {
        if (e.target === els.letterModal) closeLetter();
      });

      window.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && els.letterModal.classList.contains("open")) closeLetter();
      });
    }

    /* =========================
       Boot
    ========================== */
    function boot() {
      initMusic();
      initParticles();
      initParallax();
      bindEvents();
      createCrumbs();
      showLoading();

      // Subtle Three.js availability touchpoint: CDN is loaded for easy future 3D extension.
      // The vinyl itself uses optimized CSS 3D for broad device compatibility.
      if (typeof THREE === "undefined") {
        console.info("Three.js không tải được, website vẫn dùng CSS 3D fallback.");
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", () => {
        try { boot(); } catch (err) {
          console.warn("Website khởi động bằng fallback vì có lỗi không mong muốn:", err);
          showScene("start");
        }
      });
    } else {
      try { boot(); } catch (err) {
        console.warn("Website khởi động bằng fallback vì có lỗi không mong muốn:", err);
        showScene("start");
      }
    }
  </script>
