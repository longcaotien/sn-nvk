    .stylus {
      position: absolute;
      left: 18px;
      bottom: -28px;
      width: 3px;
      height: 28px;
      border-radius: 3px;
      background: #f7eed5;
      transform: rotate(-10deg);
      box-shadow: 0 0 8px rgba(255,211,106,.65);
